{
  "name": "soft-transit-worker",
  "main": "src/index.js",
  "compatibility_date": "2024-04-01",
  "compatibility_flags": ["nodejs_compat"],

  // Variables d'environnement (valeurs non-secrètes)
  "vars": {
    "ENVIRONMENT": "production"
  },

  // Secrets à définir via : wrangler secret put BACKEND_URL
  // BACKEND_URL = URL de ton serveur Express (ex: https://api.mondomaine.com)

  // Routes — API sur le sous-domaine api.softtransit.net
  "routes": [
    {
      "pattern": "api.softtransit.net/*",
      "zone_name": "softtransit.net"
    }
  ],

  // Limites worker (plan gratuit : 10ms CPU / 128MB)
  "limits": {
    "cpu_ms": 50
  }
}
